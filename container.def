BootStrap: docker
From: rocker/r-ver:4.5.3

%post
   apt-get -y update
   apt-get install -y libudunits2-dev libproj-dev libgdal-dev
   R -e 'install.packages(c("remotes", "mgcv"))'
   R -e 'install.packages("INLA", repos=c(getOption("repos"), INLA="https://inla.r-inla-download.org/R/stable"), dep=TRUE)'

%environment
   export LC_ALL=C

%labels
   Author David L Miller
